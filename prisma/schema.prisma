generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                          String          @id @default(cuid())
  remoteId                    String          @unique
  name                        String
  displayName                 String?
  type                        String?
  balance                     Decimal?
  currency                    String?         @default("USD")
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  excludeFromSurplus          Boolean         @default(false)
  isDebt                      Boolean         @default(false)
  showInSidebar               Boolean         @default(true)
  excludeFromAssetCalculation Boolean         @default(false)
  showTransactions            Boolean         @default(true)
  tiedCategories              Category[]
  mortgage                    MortgageDetail?
  debtDetail                  DebtDetail?
  transactions                Transaction[]
}

model MortgageDetail {
  id             String              @id @default(cuid())
  accountId      String              @unique
  interestRate   Decimal
  monthlyPayment Decimal
  startDate      DateTime
  termMonths     Int                 @default(360)
  homeValue      Decimal?
  manualHomeValue Decimal?
  originalBalance Decimal?
  address        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  providers      HomeValueProvider[]
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model DebtDetail {
  id                String   @id @default(cuid())
  accountId         String   @unique
  interestRate      Decimal
  minimumPayment    Decimal
  remainingPayments Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model HomeValueProvider {
  id         String         @id @default(cuid())
  name       String
  url        String
  lastValue  Decimal?
  lastSync   DateTime?
  mortgageId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  mortgage   MortgageDetail @relation(fields: [mortgageId], references: [id], onDelete: Cascade)

  @@index([mortgageId])
}

model Category {
  id            String             @id @default(cuid())
  name          String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  displayOrder  Int                @default(0)
  tiedAccountId String?
  tiedAccount   Account?           @relation(fields: [tiedAccountId], references: [id], onDelete: SetNull)
  commitments   Commitment[]
  splits        TransactionSplit[]
  isPaused      Boolean            @default(false)
  configs       YearlyCategory[]
  savingsGoals  SavingsGoal[]

  @@index([name])
  @@index([tiedAccountId])
}

model BudgetYear {
  id        String           @id @default(cuid())
  year      Int              @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  configs   YearlyCategory[]
}

model YearlyCategory {
  id            String     @id @default(cuid())
  yearId        String
  categoryId    String
  monthlyBudget Decimal    @default(0)
  adjustment    Decimal    @default(0)
  rollover      Decimal    @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  category      Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  year          BudgetYear @relation(fields: [yearId], references: [id], onDelete: Cascade)

  @@unique([yearId, categoryId])
}

model Transaction {
  id              String             @id @default(cuid())
  remoteId        String?            @unique
  date            DateTime
  amount          Decimal
  payee           String
  memo            String?
  posted          Boolean            @default(true)
  accountId       String
  externalOrderId String?            @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  rawPayee        String?
  isHidden        Boolean            @default(false)
  account         Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalOrder   ExternalOrder?     @relation(fields: [externalOrderId], references: [id], onDelete: SetNull)
  splits          TransactionSplit[]

  @@index([date])
  @@index([accountId])
  @@index([payee])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  categoryId    String?
  amount        Decimal
  memo          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([categoryId])
}

model ExternalOrder {
  id          String              @id @default(cuid())
  orderId     String              @unique
  source      String              @default("AMAZON") // AMAZON, WALMART, LOWES, etc
  date        DateTime
  totalAmount Decimal
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       ExternalOrderItem[]
  transaction Transaction?
}

model ExternalOrderItem {
  id              String        @id @default(cuid())
  externalOrderId String
  title           String
  rawTitle        String?
  price           Decimal
  quantity        Int           @default(1)
  categoryHint    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  externalOrder   ExternalOrder @relation(fields: [externalOrderId], references: [id], onDelete: Cascade)

  @@index([externalOrderId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeys   ApiKey[]
}

model ApiKey {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String
  userId    String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Settings {
  id                    String    @id @default("global")
  savingsTarget         Decimal   @default(650.00)
  simpleFinToken        String?
  lastSync              DateTime?
  savingsCategoryId     String?
  monthlyIncome         Decimal   @default(5000.00)
  backupRetentionDays   Int       @default(30)
  paycheckEnabled       Boolean   @default(false)
  paycheckAmount        Decimal   @default(0.00)
  paycheckFrequency     String    @default("BI_WEEKLY")
  paycheckNextDate      DateTime?
  rentcastApiKey        String?
  aiEnabled             Boolean   @default(false)
  aiBaseUrl             String?
  aiApiKey              String?
  aiModel               String?
  aiChatId              String?
  aiThinkingEnabled     Boolean   @default(false)
  aiThinkingEffort      String?
}

model Commitment {
  id          String    @id @default(cuid())
  name        String
  amount      Decimal
  frequency   String    @default("MONTHLY")
  type        String    @default("SUBSCRIPTION")
  nextDueDate DateTime?
  categoryId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  targetDate    DateTime?
  categoryId    String?   // Optional link to budget Category
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}
