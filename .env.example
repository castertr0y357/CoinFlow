# Auth Security
APP_PASSWORD="admin"
SECURE_COOKIES="true" # Set to false if running production build over HTTP

# Database connection string
DATABASE_URL="postgresql://budgetuser:budgetpassword@localhost:5433/webbudget"

# AI Configuration (OpenAI compatible)
OPENAI_BASE_URL="https://ai-url-here/v1"
OPENAI_API_KEY="your-api-key-here"
AI_MODEL="gemma4:e4b"

# NextAuth configuration (Legacy/Compatibility)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Internal API Key for Background Sync
NEXT_PUBLIC_INTERNAL_API_KEY="your-internal-key-here"
