{
  "manifest_version": 3,
  "name": "CoinFlow Purchase Sync",
  "version": "1.9",
  "description": "Automatically sync purchases from Amazon, Walmart, and Lowe's to CoinFlow.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.walmart.com/*",
    "https://*.lowes.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/gp/css/order-history*", "https://www.amazon.com/your-orders/orders*"],
      "js": ["utils.js", "content-scripts/amazon.js"]
    },
    {
      "matches": ["https://www.walmart.com/orders*", "https://www.walmart.com/account/order-history*"],
      "js": ["utils.js", "content-scripts/walmart.js"]
    },
    {
      "matches": ["https://www.lowes.com/mylowes/orders*"],
      "js": ["utils.js", "content-scripts/lowes.js"]
    }
  ]
}
